NEXT_PUBLIC_WHATSAPP_NUMBER=5500000000000
NEXT_PUBLIC_SITE_NAME=Café Brasil Colonial
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mercado Pago - use primeiro as credenciais de teste
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Opcional: a API usa este pagador fictício somente com credenciais TEST
MERCADO_PAGO_TEST_PAYER_EMAIL=test_payer@testuser.com
# auto tenta stage e, se a aplicação recusar a política, tenta o ambiente padrão
MERCADO_PAGO_SUBSCRIPTIONS_TEST_SCOPE=default

# Loja
STANDARD_SHIPPING_PRICE=18.90
FREE_SHIPPING_THRESHOLD=199
ORDER_DATABASE_PATH=./data/orders.db

# Produção: se configurado, substitui automaticamente o SQLite local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Área do cliente
# Gere com: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
CUSTOMER_DATA_ENCRYPTION_KEY=
# Recuperação de senha por e-mail (produção)
RESEND_API_KEY=
CUSTOMER_EMAIL_FROM="Café Brasil Colonial <contato@seudominio.com>"

# Painel administrativo
ADMIN_EMAIL=admin@cafebrasilcolonial.com.br
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
